rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isPostOwner(postId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/posts/$(postId)).data.userId == request.auth.uid;
    }

    function validatePost() {
      let post = request.resource.data;
      return 
        // Required fields
        post.content is string &&
        post.userId is string &&
        post.username is string &&
        post.userAvatar is string &&
        post.createdAt is timestamp &&
        post.updatedAt is timestamp &&
        post.likes is number && post.likes >= 0 &&
        post.commentsCount is number && post.commentsCount >= 0 &&
        post.shares is number && post.shares >= 0 &&
        post.visibility in ['public', 'private', 'friends'] &&
        post.tags is list &&

        // Optional fields
        (!('mediaUrls' in post) || (post.mediaUrls is list)) &&
        (!('mediaType' in post) || post.mediaType in ['image', 'video', null]) &&
        (!('pollOptions' in post) || (
          post.pollOptions is list && 
          post.pollOptions.size() <= 4 &&
          post.pollOptions.size() >= 0
        )) &&
        (!('fitnessData' in post) || (
          post.fitnessData.keys().hasAll(['steps', 'calories', 'duration', 'activityType']) &&
          (!('steps' in post.fitnessData) || post.fitnessData.steps is number) &&
          (!('calories' in post.fitnessData) || post.fitnessData.calories is number) &&
          (!('duration' in post.fitnessData) || post.fitnessData.duration is number) &&
          (!('activityType' in post.fitnessData) || post.fitnessData.activityType is string)
        ));
    }

    function validateProduct() {
      let product = request.resource.data;
      return 
        // Basic Information validation
        product.name is string && product.name.size() > 0 &&
        product.description is string &&
        (('sku' in product && product.sku is string) || !('sku' in product)) &&
        (('brand' in product && product.brand is string) || !('brand' in product)) &&
        product.category is string &&
        (('tags' in product && product.tags is list) || !('tags' in product)) &&
        (('features' in product && product.features is list) || !('features' in product)) &&
        
        // Pricing and Inventory validation
        product.price is number && product.price >= 0 &&
        (!('discountedPrice' in product) || product.discountedPrice is number) &&
        product.stock is number && product.stock >= 0 &&
        (('lowStockThreshold' in product && product.lowStockThreshold is number) || !('lowStockThreshold' in product)) &&
        product.stockStatus in ['in_stock', 'out_of_stock', 'backorder'] &&
        
        // Images and Media validation
        (('mainImage' in product && product.mainImage is string) || !('mainImage' in product)) &&
        (('additionalImages' in product && product.additionalImages is list) || !('additionalImages' in product)) &&
        (('imageGallery' in product && product.imageGallery is list) || !('imageGallery' in product)) &&
        (!('videoUrl' in product) || product.videoUrl is string) &&
        
        // Long Description and Rich Content
        (('longDescription' in product && product.longDescription is string) || !('longDescription' in product)) &&
        
        // Cross-sell and Up-sell Products
        (('crossSellProducts' in product && product.crossSellProducts is list) || !('crossSellProducts' in product)) &&
        (('upSellProducts' in product && product.upSellProducts is list) || !('upSellProducts' in product)) &&
        
        // Shipping and Attributes validation
        (('weight' in product && product.weight is number) || !('weight' in product)) &&
        (('weightUnit' in product && product.weightUnit in ['kg', 'lb']) || !('weightUnit' in product)) &&
        (('dimensions' in product && product.dimensions is map) || !('dimensions' in product)) &&
        (!('dimensions' in product) || (
          product.dimensions.length is number && 
          product.dimensions.width is number && 
          product.dimensions.height is number &&
          product.dimensions.unit in ['cm', 'in']
        )) &&
        (('shippingClass' in product && product.shippingClass is string) || !('shippingClass' in product)) &&
        (('variants' in product && product.variants is list) || !('variants' in product))
    }

    function validateProductCategory() {
      let category = request.resource.data;
      return 
        // Basic Information validation
        category.name is string && category.name.size() > 0 &&
        (('description' in category && category.description is string) || !('description' in category)) &&
        (('image' in category && category.image is string) || !('image' in category)) &&
        (('icon' in category && category.icon is string) || !('icon' in category)) &&
        (('gradientStart' in category && category.gradientStart is string) || !('gradientStart' in category)) &&
        (('gradientEnd' in category && category.gradientEnd is string) || !('gradientEnd' in category)) &&
        (('featured' in category && category.featured is bool) || !('featured' in category)) &&
        category.slug is string && category.slug.size() > 0 &&
        category.createdAt is timestamp &&
        category.updatedAt is timestamp;
    }

    function validateWorkoutCategory() {
      let category = request.resource.data;
      return 
        category.name is string && category.name.size() > 0 &&
        category.iconUrl is string && category.iconUrl.size() > 0 &&
        category.backgroundColor is string && category.backgroundColor.matches('^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{8})$');
    }

    function validateWorkout() {
      let workout = request.resource.data;
      return 
        workout.title is string && workout.title.size() > 0 &&
        workout.description is string &&
        workout.image is string && workout.image.size() > 0 &&
        workout.duration is number && workout.duration > 0 &&
        workout.intensity in ['Low', 'Medium', 'High'] &&
        workout.type in ['challenge', 'cardio', 'strength', 'workout'] &&
        workout.categoryId is string && workout.categoryId.size() > 0;
    }

    function validateBanner() {
      let banner = request.resource.data;
      return 
        banner.title is string && banner.title.size() > 0 &&
        banner.description is string &&
        banner.imageUrl is string && banner.imageUrl.size() > 0 &&
        banner.offerPercentage is number &&
        banner.offerPercentage >= 0 &&
        banner.boxShadow is string &&
        banner.createdAt is timestamp &&
        banner.updatedAt is timestamp;
    }

    function validateShopSection() {
      let section = request.resource.data;
      return 
        section.title is string && section.title.size() > 0 &&
        section.description is string &&
        section.productIds is list &&
        section.order is number && section.order >= 0 &&
        section.createdAt is timestamp &&
        section.displayType in ['scroll', 'grid'];
    }

    function validateAddress() {
      let address = request.resource.data;
      return 
        address.type in ['home', 'office', 'other'] &&
        address.name is string && address.name.size() > 0 &&
        address.phoneNumber is string && address.phoneNumber.matches('^[0-9]{10}$') &&
        address.addressLine1 is string && address.addressLine1.size() > 0 &&
        (address.addressLine2 == null || (address.addressLine2 is string)) &&
        address.city is string && address.city.size() > 0 &&
        address.state is string && address.state.size() > 0 &&
        address.pincode is string && address.pincode.matches('^[0-9]{6}$') &&
        address.isDefault is bool;
    }

    function validatePollOption() {
      let option = request.resource.data;
      return 
        option.text is string && option.text.size() > 0 &&
        option.votes is number && option.votes >= 0;
    }

    function validateComment() {
      let comment = request.resource.data;
      return 
        comment.userId == request.auth.uid &&
        comment.content is string &&
        comment.likes is number &&
        comment.createdAt is timestamp &&
        (!('parentCommentId' in comment) || comment.parentCommentId is string);
    }

    // Order validation functions
    function isValidOrderItem() {
      let item = request.resource.data;
      return item.keys().hasAll(['id', 'name', 'mainImage', 'price', 'discountedPrice', 'quantity', 'totalItemPrice']) &&
        item.id is string &&
        item.name is string &&
        item.mainImage is string &&
        item.price is number && item.price >= 0 &&
        item.discountedPrice is number && item.discountedPrice >= 0 &&
        item.quantity is number && item.quantity > 0 &&
        item.totalItemPrice is number && item.totalItemPrice >= 0;
    }

    function isValidOrderStatus() {
      let status = request.resource.data.orderStatus;
      return status.keys().hasAll(['current', 'history']) &&
        status.current in ['pending', 'confirmed', 'shipped', 'delivered', 'cancelled'] &&
        status.history is list &&
        status.history[0].keys().hasAll(['status', 'timestamp', 'message']);
    }

    function isValidOrderData() {
      let order = request.resource.data;
      return order.keys().hasAll([
        'items', 'orderSummary', 'address', 'payment', 
        'orderStatus', 'customerInfo', 'metadata'
      ]) &&
      order.orderStatus.current in ['pending', 'confirmed', 'processing', 'shipped', 'delivered', 'cancelled'] &&
      order.orderStatus.history is list &&
      order.orderStatus.history.size() > 0 &&
      order.payment.method in ['Cash on Delivery', 'Online Payment'] &&
      order.payment.status in ['pending', 'not_initiated', 'completed', 'failed'] &&
      order.metadata.createdAt is number &&
      order.metadata.updatedAt is number;
    }

    // Exercise category validation
    function isValidExerciseCategory() {
      let category = request.resource.data;
      return category.name is string 
        && category.name.size() > 0 
        && category.name.size() <= 100 
        && (category.description == null || (category.description is string && category.description.size() <= 500))
        && (category.imageUrl == null || category.imageUrl is string)
        && (category.cloudinaryImageId == null || category.cloudinaryImageId is string)
        && category.createdAt is timestamp
        && category.updatedAt is timestamp;
    }

    // Exercise validation
    function isValidExercise() {
      let exercise = request.resource.data;
      return exercise.categoryId is string 
        && exercise.name is string 
        && exercise.name.size() > 0 
        && exercise.name.size() <= 100
        && exercise.description is string 
        && exercise.description.size() <= 1000
        && (exercise.gifUrl == null || (exercise.gifUrl is string && exercise.gifUrl.matches('https://.*')))
        && (exercise.videoUrl == null || (exercise.videoUrl is string && exercise.videoUrl.matches('https://.*')))
        && (exercise.youtubeUrl == null || (exercise.youtubeUrl is string && exercise.youtubeUrl.matches('https://(www\\.)?youtube\\.com/.*')))
        && (exercise.additionalImages == null || (exercise.additionalImages is list && exercise.additionalImages.size() <= 10))
        && (exercise.cloudinaryGifId == null || exercise.cloudinaryGifId is string)
        && (exercise.cloudinaryVideoId == null || exercise.cloudinaryVideoId is string)
        && (exercise.cloudinaryImageIds == null || (exercise.cloudinaryImageIds is list && exercise.cloudinaryImageIds.size() <= 10))
        && exercise.createdAt is timestamp
        && exercise.updatedAt is timestamp;
    }

    // Validate AI recommendation data structure
    function validateAiRecommendation() {
      let rec = request.resource.data;
      return rec.keys().hasAll(['recommendations', 'lastUpdate']) &&
        rec.recommendations is list &&
        rec.lastUpdate is number &&
        rec.recommendations.size() <= 10 &&
        rec.recommendations[0].keys().hasAll(['id', 'type', 'title', 'description', 'timestamp']) &&
        rec.recommendations[0].type in ['workout', 'nutrition', 'mental', 'sleep', 'cardio'] &&
        rec.recommendations[0].title is string &&
        rec.recommendations[0].description is string &&
        rec.recommendations[0].timestamp is number;
    }

    // Validate water log data structure
    function validateWaterData() {
      let data = request.resource.data;
      return data.keys().hasAll(['current', 'target', 'unit', 'lastDrink', 'logs', 'lastResetDate']) &&
        data.current is number && data.current >= 0 &&
        data.target is number && data.target > 0 &&
        data.unit is string &&
        data.lastDrink is string &&
        data.lastResetDate is string &&
        data.logs is list &&
        (data.logs.size() == 0 || (
          data.logs[0].keys().hasAll(['id', 'time', 'amount', 'timestamp', 'date']) &&
          data.logs[0].id is string &&
          data.logs[0].time is string &&
          data.logs[0].amount is number && data.logs[0].amount > 0 &&
          data.logs[0].timestamp is number &&
          data.logs[0].date is string
        ));
    }

    // Validate water history data structure
    function validateWaterHistory() {
      let data = request.resource.data;
      return data.keys().hasAll(['date', 'total', 'target', 'logs']) &&
        data.date is string &&
        data.total is number && data.total >= 0 &&
        data.target is number && data.target > 0 &&
        data.logs is list;
    }

    // Validate weight entry data structure
    function validateWeightEntry() {
      let data = request.resource.data;
      return data.keys().hasAll(['date', 'weight', 'timestamp']) &&
        data.date is string &&
        data.weight is number && data.weight > 0 &&
        data.timestamp is number;
    }

    // Validate weight goal data structure
    function validateWeightGoal() {
      let data = request.resource.data;
      return data.keys().hasAll(['weight', 'timestamp']) &&
        data.weight is number && data.weight > 0 &&
        data.timestamp is number;
    }

    // Admin collection rules
    match /admins/{userId} {
      allow read: if request.auth != null;
      allow write: if false;  // Only modifiable through backend
    }

    // Products collection rules
    match /products/{productId} {
      // Allow all users to read products
      allow read: if true;
      
      // Only admins can create products with valid data
      allow create: if isAdmin() && validateProduct();
      
      // Only admins can update products
      allow update: if isAdmin() && validateProduct();
      
      // Only admins can delete products
      allow delete: if isAdmin();
    }

    // Product Categories collection rules
    match /productCategories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && validateProductCategory();
      
      match /products/{productId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Categories collection rules
    match /categories/{categoryId} {
      // Allow all users to read categories and their workouts
      allow read: if true;
      
      // Only admins can create/update/delete categories
      allow create, update, delete: if isAdmin();
      
      // Workouts subcollection rules
      match /workouts/{workoutId} {
        // Allow all users to read workouts
        allow read: if true;
        
        // Only admins can create/update/delete workouts
        allow create, update, delete: if isAdmin();
      }
    }

    // Workout Categories Rules
    match /workoutCategories/{categoryId} {
      allow read: if true;  // Public read access
      allow create, update: if isAdmin() && validateWorkoutCategory();
      allow delete: if isAdmin();
    }

    // Workouts Rules
    match /workouts/{workoutId} {
      allow read: if true;  // Public read access
      allow create, update: if isAdmin() && validateWorkout();
      allow delete: if isAdmin();
    }

    // Shop Sections Rules
    match /shopSections/{sectionId} {
      allow read: if true;  // Public read access
      allow create: if isAdmin() && validateShopSection();
      allow update: if isAdmin() && validateShopSection();
      allow delete: if isAdmin();
    }

    // User profiles with admin access
    match /users/{userId} {
      // Allow admins to read and write all user data
      allow read, write: if isAdmin();
      
      // Allow users to read and write their own data
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Active workouts subcollection
      match /activeWorkouts/{workoutId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow create: if isAuthenticated() && request.auth.uid == userId &&
          request.resource.data.title is string &&
          request.resource.data.categoryName is string &&
          request.resource.data.imageUrl is string &&
          request.resource.data.level is string &&
          request.resource.data.startDate is string &&
          request.resource.data.totalDays is number;
        allow update: if isAuthenticated() && request.auth.uid == userId;
        allow delete: if isAuthenticated() && request.auth.uid == userId;
      }

      // Workout progress subcollection
      match /workoutProgress/{progressId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }

      // Address rules
      match /addresses/{addressId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Cart subcollection rules
      match /cart/{itemId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
      
      // Order rules
      match /orders/{orderId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && 
                     request.auth.uid == userId && 
                     request.resource.data.customerInfo.uid == userId;
        allow update: if request.auth != null && 
                     request.auth.uid == userId && 
                     request.resource.data.customerInfo.uid == userId &&
                     (request.resource.data.orderStatus.current == 'cancelled' || 
                      resource.data.orderStatus.current == 'pending');
        allow delete: if false; // Orders should never be deleted
      }
      
      // Allow access to userData subcollection
      match /userData/{document=**} {
        allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      }

      // Allow access to assistance subcollection
      match /assistance/{messageId} {
        allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      }
      
      // Allow access to user's workouts subcollection
      match /workouts/{document=**} {
        allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      }
      
      // Allow access to challenges subcollection
      match /challenges/{document=**} {
        allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      }

      // Allow access to workoutData subcollection
      match /workoutData/{document=**} {
        allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      }
      
      // User's active workouts
      match /activeWorkouts/{workoutId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow update: if isAuthenticated() && request.auth.uid == userId;
        allow delete: if isAuthenticated() && request.auth.uid == userId;
      }
      
      // Custom Workouts Rules
      match /customWorkouts/{document=**} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // Current day workout data
      match /customWorkout/currentDayWorkout {
        allow read, write: if isOwner(userId);
      }

      // AI Recommendations Rules
      match /userData/aiRecommendations {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && validateAiRecommendation();
      }

      // Water Rules
      match /userData/water {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && validateWaterData();
      }

      // Water History Rules
      match /userData/waterHistory/{date} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && validateWaterHistory();
      }

      // Weight Rules
      match /userData/weight/{entryId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && validateWeightEntry();
        allow delete: if isOwner(userId);
      }

      // Weight Goals Rules
      match /userData/profile/weightGoals/{goalType} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && validateWeightGoal();
      }

      // Weight History Rules
      match /weightHistory/{entryId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && validateWeightEntry();
        allow delete: if isOwner(userId);
      }
    }
    
    // Workouts
    match /workouts/{workoutId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow create: if request.auth != null;
    }

    // Weights
    match /weights/{weightId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Profile data rules
    match /userdata/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      match /profile/{document=**} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Allow users to read public exercise data
    match /exercises/{exerciseId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Allow all authenticated users to read challenges
    match /challenges/{challengeId} {
      allow read: if request.auth != null;
      // Only allow admins to write to challenges
      allow write: if isAdmin();
      
      // Allow users to commit to challenges
      match /commits/{commitId} {
        allow read: if request.auth != null;
        allow create, write: if request.auth != null && request.resource.data.userId == request.auth.uid;
      }
    }
    
    // Admin Notes collection rules
    match /admin-notes/{noteId} {
      allow read, write: if isAdmin();
    }

    // Allow admins to read all collections
    match /{collection}/{document=**} {
      allow read: if isAdmin();
    }

    // Deny access to all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Products collection rules
    match /products/{productId} {
      allow write: if request.auth != null && 
        (request.resource.data.categoryId is string ||
         request.resource.data.categoryId == null);
    }
    
    match /categories/{categoryId} {
      allow read: if true;  // Public read access
      allow write: if isAdmin();  // Only admin can modify categories
    }
    
    // Stats collection rules
    match /stats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
      
      function isValidStat() {
        let stat = request.resource.data;
        return stat.title is string &&
               stat.title.size() > 0 &&
               stat.value is string &&
               stat.change is number &&
               stat.icon in ['currency', 'cart', 'users', 'chart', 'sparkles', 'fire', 'heart', 'star'] &&
               stat.gradient is string &&
               stat.order is number &&
               stat.isActive is bool;
      }
    }
    
    // Banner Rules
    match /products/{productId}/banners/{bannerId} {
      allow read: if true;  // Public read access
      allow create, update: if isAdmin() && validateBanner();
      allow delete: if isAdmin();
    }

    // Exercises Categories Rules
    match /exercisesCategories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && isAdmin();
      
      match /name/{nameId} {
        allow read: if true;
        allow create, update, delete: if isAuthenticated() && isAdmin();
      }
      
      match /{document=**} {
        allow read: if true;
        allow create, update, delete: if isAuthenticated() && isAdmin();
      }
    }

    // Exercises collection rules
    match /exercises/{exerciseId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && isAdmin();
    }

    // Workout Days
    match /categories/{categoryId}/workouts/{workoutId}/days/{dayId} {
      allow read: if true;
      allow create: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && isAdmin() && (
        // Allow updating only specific fields
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['exercises']) || isAdmin()
      );
      allow delete: if isAuthenticated() && isAdmin();
      
      match /exercises/{exerciseId} {
        allow read: if true;
        allow write: if isAuthenticated() && isAdmin();
      }
    }

    // Exercises collection
    match /exercises/{exerciseId} {
      allow read: if true;
      
      function isValidExercise() {
        let exercise = request.resource.data;
        return exercise.name is string &&
               exercise.name.size() <= 100 &&
               exercise.description is string &&
               exercise.description.size() <= 1000 &&
               exercise.categoryId is string &&
               (exercise.gifUrl == null || exercise.gifUrl is string) &&
               (exercise.videoUrl == null || exercise.videoUrl is string) &&
               (exercise.youtubeUrl == null || exercise.youtubeUrl is string) &&
               (exercise.additionalImages == null || exercise.additionalImages is list) &&
               (exercise.cloudinaryIds == null || exercise.cloudinaryIds is map);
      }

      allow create: if isAdmin() && isValidExercise();
      allow update: if isAdmin() && isValidExercise();
      allow delete: if isAdmin();
    }

    // Exercises subcollection under categories
    match /exercises/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /exercises/{exerciseId} {
        allow read: if true;
        allow write: if isAdmin();

        function isValidExercise() {
          let exercise = request.resource.data;
          return exercise.name is string &&
                 exercise.name.size() <= 100 &&
                 exercise.description is string &&
                 exercise.description.size() <= 1000 &&
                 exercise.categoryId is string &&
                 (exercise.gifUrl == null || exercise.gifUrl is string) &&
                 (exercise.videoUrl == null || exercise.videoUrl is string) &&
                 (exercise.youtubeUrl == null || exercise.youtubeUrl is string) &&
                 (exercise.additionalImages == null || exercise.additionalImages is list) &&
                 (exercise.cloudinaryIds == null || exercise.cloudinaryIds is map);
        }

        allow create: if isAdmin() && isValidExercise();
        allow update: if isAdmin() && isValidExercise();
        allow delete: if isAdmin();
      }
    }

    // Exercise Rules
    match /exercises/{exerciseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders collection rules
    match /orders/{orderId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.customerInfo.uid || isAdmin()
      );
      allow create: if request.auth != null && 
                   request.auth.uid == request.resource.data.customerInfo.uid && 
                   isValidOrderData();
      allow update: if request.auth != null && (
        (request.auth.uid == resource.data.customerInfo.uid && 
         request.resource.data.customerInfo.uid == resource.data.customerInfo.uid &&
         (request.resource.data.orderStatus.current == 'cancelled' || 
          resource.data.orderStatus.current == 'pending')) || 
        isAdmin()
      );
      allow delete: if false; // Orders should never be deleted
    }

    // Active Workouts Rules
    match /users/{userId}/activeWorkouts/{workoutId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && 
                   request.auth.uid == userId && 
                   request.resource.data.keys().hasAll(['title', 'categoryName', 'imageUrl', 'level', 'startDate', 'totalDays']) &&
                   request.resource.data.title is string &&
                   request.resource.data.categoryName is string &&
                   request.resource.data.imageUrl is string &&
                   request.resource.data.level is string &&
                   request.resource.data.startDate is string &&
                   request.resource.data.totalDays is number;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Allow access to user document itself for active workouts
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Exercises collection rules
    match /exercises/{exerciseId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && isAdmin();
    }

    // Exercise Categories Rules
    match /exerciseCategories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && isAdmin();
    }

    // Individual Exercise Documents
    match /exercises/{exerciseId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && isAdmin();

      // Exercise Details
      match /details/{detailId} {
        allow read: if true;
        allow write: if isAuthenticated() && isAdmin();
      }
    }

    // Helper function to check if user is admin
    function isAdminUser() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Diet Categories rules
    match /dietCategories/{categoryId} {
      allow read, write: if request.auth != null;

      // Recipes subcollection rules
      match /recipes/{recipeId} {
        allow read, write: if request.auth != null;
      }

      // Diets subcollection rules
      match /diets/{dietId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null && validateMealPlan();
        allow delete: if request.auth != null;

        function validateMealPlan() {
          let incomingData = request.resource.data;
          let mealPlans = incomingData.mealPlans;
          
          return mealPlans is list && 
            mealPlans.size() > 0 && 
            mealPlans[0].dayNumber is number && 
            mealPlans[0].dayNumber > 0 &&
            mealPlans[0].id is string &&
            mealPlans[0].breakfast is list &&
            mealPlans[0].lunch is list &&
            mealPlans[0].dinner is list &&
            mealPlans[0].snacks is list;
        }
      }
    }

    // Nutrition rules
    match /users/{userId}/nutrition/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Product Categories rules
    match /productCategories/{categoryId} {
      allow read: if true;
      allow create, update: if isAuthenticated() && isAdmin();
      allow delete: if isAuthenticated() && isAdmin();
    }

    // Blog rules
    match /blogs/{blogId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;

      function validateBlog() {
        let blog = request.resource.data;
        return blog.keys().hasAll([
          'title', 'content', 'summary', 'imageUrl', 'category', 'tags',
          'status', 'author', 'createdAt', 'updatedAt'
        ]) &&
        blog.title is string && blog.title.size() > 0 &&
        blog.content is string && blog.content.size() > 0 &&
        blog.summary is string && blog.summary.size() > 0 &&
        blog.imageUrl is string &&
        blog.category is string && blog.category.size() > 0 &&
        blog.tags is list &&
        blog.status in ['draft', 'published'] &&
        blog.author.keys().hasAll(['id', 'name']);
      }
    }

    // Marketing suggestions
    match /marketing_suggestions/{suggestionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Marketing posts
    match /marketing_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.keys().hasAll(['type', 'title', 'content', 'userId']);
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Blog data fetch rules
    match /blogs/{blogId} {
      allow read: if true;  // Allow public read access
      allow write: if isAdmin();  // Only admin can modify blog data
    }

    // Recipe collection
    match /recipes/{recipeId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                      isOwner(request.resource.data.userId) &&
                      isValidMeal();
      allow update, delete: if isAuthenticated() && 
                             isOwner(resource.data.userId);
    }

    // Diet collection
    match /diets/{dietId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                      isOwner(request.resource.data.userId) &&
                      isValidMeal();
      allow update, delete: if isAuthenticated() && 
                             isOwner(resource.data.userId);
    }

    // Basic validation functions
    function hasValidFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }

    function isValidString(field) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() > 0;
    }

    function isValidNumber(field) {
      return request.resource.data[field] is number && 
             request.resource.data[field] >= 0;
    }

    function isValidArray(field) {
      return request.resource.data[field] is list;
    }

    // Meal validation
    function isValidMeal() {
      let requiredFields = [
        'name', 'description', 'ingredients', 'userId', 
        'userName', 'createdAt', 'updatedAt', 'nutrition'
      ];
      
      let validBasicFields = hasValidFields(requiredFields) &&
                            isValidString('name') &&
                            isValidString('description') &&
                            isValidArray('ingredients');
      
      let validNutrition = request.resource.data.nutrition is map &&
                          request.resource.data.nutrition.calories is number &&
                          request.resource.data.nutrition.protein is number &&
                          request.resource.data.nutrition.carbs is number &&
                          request.resource.data.nutrition.fat is number;
      
      return validBasicFields && validNutrition;
    }

    // Recipes collection
    match /recipes/{recipeId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                      isOwner(request.resource.data.userId) &&
                      isValidMeal();
      allow update, delete: if isAuthenticated() && 
                             isOwner(resource.data.userId);
    }

    // Diets collection
    match /diets/{dietId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                      isOwner(request.resource.data.userId) &&
                      isValidMeal();
      allow update, delete: if isAuthenticated() && 
                             isOwner(resource.data.userId);
    }

    // Meals collection rules
    match /meals/{mealId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Public read access for users
    match /users/{userId} {
      allow read: if true;  // Allow reading user profiles
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Public read access for recipes and diets
    match /recipes/{recipeId} {
      allow read: if true;  // Anyone can read recipes
      allow write: if request.auth != null;  // Only authenticated users can write
    }

    match /diets/{dietId} {
      allow read: if true;  // Anyone can read diets
      allow write: if request.auth != null;  // Only authenticated users can write
    }

    // User Stats Rules
    match /userStats/{userId} {
      // Allow users to read their own stats and admins to read all stats
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow creation only by the owner with valid data
      allow create: if isOwner(userId) && validateUserStats();
      
      // Allow updates only by the owner and validate the update
      allow update: if isOwner(userId) && validateUserStatsUpdate();
    }

    // Helper functions for user stats validation
    function validateUserStats() {
      let stats = request.resource.data;
      return stats.keys().hasAll([
        'userId', 'userName', 'userImage', 'likedMeals', 
        'savedMeals', 'comments', 'sharedMeals', 
        'totalLikes', 'totalComments', 'totalShares',
        'createdAt', 'updatedAt'
      ]) &&
      stats.userId == request.auth.uid &&
      stats.likedMeals is list &&
      stats.savedMeals is list &&
      stats.comments is list &&
      stats.sharedMeals is list &&
      stats.totalLikes is number && stats.totalLikes >= 0 &&
      stats.totalComments is number && stats.totalComments >= 0 &&
      stats.totalShares is number && stats.totalShares >= 0 &&
      stats.createdAt is timestamp &&
      stats.updatedAt is timestamp;
    }

    function validateUserStatsUpdate() {
      let stats = request.resource.data;
      let oldStats = resource.data;
      
      // Ensure userId cannot be changed
      return stats.userId == oldStats.userId &&
      
      // Validate all fields
      validateUserStats() &&
      
      // Additional update-specific validations
      stats.createdAt == oldStats.createdAt &&
      stats.updatedAt > oldStats.updatedAt;
    }

    // Update meal rules to allow social interactions
    match /meals/{mealId} {
      // Allow authenticated users to read meals
      allow read: if true;
      
      // Allow creation by authenticated users
      allow create: if isAuthenticated();
      
      // Allow updates for social interactions
      allow update: if isAuthenticated() && (
        // Allow owner to update everything
        resource.data.userId == request.auth.uid ||
        
        // Allow social interactions for other users
        (
          // Only allow updating social fields
          request.resource.data.diff(resource.data).affectedKeys()
            .hasAll(['likes', 'comments', 'shares']) &&
          
          // Ensure non-social fields remain unchanged
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.name == resource.data.name &&
          request.resource.data.description == resource.data.description &&
          
          // Validate likes array
          (!('likes' in request.resource.data.diff(resource.data)) ||
            request.resource.data.likes is list) &&
          
          // Validate comments array
          (!('comments' in request.resource.data.diff(resource.data)) ||
            (request.resource.data.comments is list &&
             validateComments(request.resource.data.comments))) &&
          
          // Validate shares count
          (!('shares' in request.resource.data.diff(resource.data)) ||
            (request.resource.data.shares is number &&
             request.resource.data.shares >= resource.data.shares))
        )
      );
    }

    // Helper function to validate comments
    function validateComments(comments) {
      return comments.size() > 0 &&
      comments[-1].keys().hasAll([
        'id', 'userId', 'userName', 'userImage',
        'content', 'createdAt', 'likes'
      ]) &&
      comments[-1].userId == request.auth.uid &&
      comments[-1].content is string &&
      comments[-1].content.size() > 0 &&
      comments[-1].content.size() <= 1000 && // Limit comment length
      comments[-1].createdAt is timestamp &&
      comments[-1].likes is number &&
      comments[-1].likes >= 0;
    }

    // Wishlist rules - nested under users collection
    match /users/{userId}/wishlist/{itemId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Reviews collection rules
    match /reviews/{reviewId} {
      allow read: if true;  // Anyone can read reviews
      allow create: if request.auth != null &&  // Must be authenticated
                   request.resource.data.userId == request.auth.uid &&  // Can only create reviews as themselves
                   request.resource.data.rating is number &&  // Rating must be a number
                   request.resource.data.rating >= 1 &&  // Rating must be at least 1
                   request.resource.data.rating <= 5;  // Rating must be at most 5
      allow update: if request.auth != null &&
                   resource.data.userId == request.auth.uid;  // Can only update own reviews
      allow delete: if request.auth != null &&
                   resource.data.userId == request.auth.uid;  // Can only delete own reviews
    }

    // Suggestions collection rules
    match /suggestions/{suggestionId} {
      allow create: if isAuthenticated() && validateSuggestion();
      allow read: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if isAdmin();
    }

    function validateSuggestion() {
      let suggestion = request.resource.data;
      return 
        // Required fields
        suggestion.userId is string &&
        suggestion.userId == request.auth.uid &&
        suggestion.name is string && suggestion.name.size() > 0 &&
        suggestion.email is string && suggestion.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
        suggestion.message is string && suggestion.message.size() > 0 &&
        suggestion.type in ['suggestion', 'contact'] &&
        suggestion.status == 'pending' &&
        suggestion.createdAt is timestamp &&

        // Optional fields
        (!('subject' in suggestion) || suggestion.subject is string) &&
        (!('photoURL' in suggestion) || suggestion.photoURL is string);
    }

    // Community collection rules
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid || 
        (resource.data.userId != request.auth.uid && 
         request.resource.data.diff(resource.data).affectedKeys().hasAll(['likes', 'commentsCount', 'savedBy']))
      );
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;

      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuthenticated() && userId == request.auth.uid;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update: if isAuthenticated() && (
          request.resource.data.userId == request.auth.uid || 
          (resource.data.userId != request.auth.uid && 
           request.resource.data.diff(resource.data).affectedKeys().hasAll(['likes']))
        );
        allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;

        match /likes/{userId} {
          allow read: if true;
          allow write: if isAuthenticated() && userId == request.auth.uid;
        }
      }
    }

    match /users/{userId}/followers/{followerId} {
      allow read: if true;
      allow write: if isAuthenticated() && followerId == request.auth.uid;
    }

    match /users/{userId}/following/{followingId} {
      allow read: if true;
      allow write: if isAuthenticated() && userId == request.auth.uid;
    }

    match /users/{userId}/savedPosts/{postId} {
      allow read: if isAuthenticated() && userId == request.auth.uid;
      allow write: if isAuthenticated() && userId == request.auth.uid;
    }
    
    // Workout stats collection rules
    match /users/{userId}/workoutStats/{statId} {
      allow read: if isAuthenticated() && userId == request.auth.uid;
      allow create: if isAuthenticated() && userId == request.auth.uid && validateWorkoutStats();
      allow update: if isAuthenticated() && userId == request.auth.uid;
      allow delete: if isAuthenticated() && userId == request.auth.uid;
    }
    
    // Validate workout stats data structure
    function validateWorkoutStats() {
      let stats = request.resource.data;
      return 
        // Required fields
        stats.date is timestamp &&
        stats.totalTime is number && stats.totalTime >= 0 &&
        stats.caloriesBurned is number && stats.caloriesBurned >= 0 &&
        stats.exercisesCompleted is number && stats.exercisesCompleted >= 0 &&
        stats.setsCompleted is number && stats.setsCompleted >= 0 &&
        stats.totalReps is number && stats.totalReps >= 0 &&
        stats.dayNumber is number && stats.dayNumber >= 0 &&
        stats.workoutId is string &&
        
        // Optional fields
        (!('notes' in stats) || stats.notes is string) &&
        (!('rating' in stats) || (stats.rating is number && stats.rating >= 1 && stats.rating <= 5)) &&
        (!('exerciseDetails' in stats) || stats.exerciseDetails is list);
    }

    // Activity feed collection rules
    match /users/{userId}/activityFeed/{activityId} {
      allow read: if isAuthenticated() && userId == request.auth.uid;
      allow create: if isAuthenticated() && userId == request.auth.uid;
      allow update: if isAuthenticated() && userId == request.auth.uid;
      allow delete: if isAuthenticated() && userId == request.auth.uid;
    }
  }
}
